<!-- ── HERO ──────────────────────────────────────────────── -->
<section class="hero">
  <canvas id="hero-canvas"></canvas>
  <div class="hero-inner container">
    <div class="hero-content">
      <div class="hero-eyebrow"><span class="eyebrow-dot"></span>British Columbia, Canada</div>
      <h1 class="hero-heading">
        <span class="hero-line"><span class="hero-line-inner l1">Finally.</span></span>
        <span class="hero-line"><span class="hero-line-inner l2">Skin That Looks</span></span>
        <span class="hero-line"><span class="hero-line-inner l3"><em>Like You Actually</em></span></span>
        <span class="hero-line"><span class="hero-line-inner l4">Slept Eight Hours.</span></span>
      </h1>
      <div class="hero-proof">
        <span class="proof-stars">★★★★★</span>
        <span class="proof-text"><strong>4.9/5</strong> from 2,400+ verified reviews</span>
        <span class="proof-sep">·</span>
        <span class="proof-text">Free shipping to Canada & US</span>
      </div>
      <p class="hero-desc">Clinical-grade actives at honest prices. We formulate for results, not for packaging. Every ingredient earns its place or it doesn't go in.</p>
      <div class="hero-ctas">
        <a href="{{ routes.all_products_collection_url }}" class="btn-primary">
          Shop All Products
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="{{ pages['our-story'].url | default: '/pages/our-story' }}" class="btn-outline">Our Story</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-product-showcase">
        <div class="hero-blob-bg"></div>
        <div class="hero-product-art">
          <!-- CSS serum bottle art -->
          <div style="display:flex;flex-direction:column;align-items:center;gap:0;">
            <div style="width:28px;height:14px;background:linear-gradient(135deg,#4E7A69,#2D4A40);border-radius:6px 6px 2px 2px;"></div>
            <div style="width:20px;height:24px;background:linear-gradient(180deg,#3A6052,#2D4A40);border-radius:2px;"></div>
            <div style="width:96px;height:180px;background:linear-gradient(160deg,#4E7A69 0%,#2D4A40 50%,#1a2e27 100%);border-radius:14px 14px 22px 22px;position:relative;overflow:hidden;box-shadow:0 20px 60px rgba(45,74,64,0.4);">
              <div style="position:absolute;top:12px;left:10px;width:10px;height:65px;background:rgba(255,255,255,0.14);border-radius:999px;filter:blur(4px);"></div>
              <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
                <div style="font-family:'Playfair Display',serif;font-size:8px;letter-spacing:0.1em;color:rgba(200,230,220,0.8);text-transform:uppercase;line-height:1.6;">Niacinamide<br>20% + Zinc</div>
              </div>
            </div>
          </div>
        </div>
        <div class="floating-badge b1" style="top:14%;left:-12%;--rot:-4deg;">✓ 20% Niacinamide</div>
        <div class="floating-badge b2" style="top:48%;right:-16%;--rot:3deg;">★★★★★ 2,400+</div>
        <div class="floating-badge b3" style="bottom:18%;left:-6%;--rot:-2deg;">🇨🇦 Made in Canada</div>
      </div>
    </div>
  </div>
  <div class="hero-scroll"><div class="scroll-line"></div>Scroll</div>
</section>

