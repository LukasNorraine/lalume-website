<!-- ── PAIN SECTION ───────────────────────────────────────── -->
<section class="pain-section">
  <div class="container">
    <div class="pain-intro">
      <span class="pain-label">"Why doesn't anything actually work?"</span>
      <h2>The skincare industry isn't built<br>to give you results.</h2>
    </div>
    <div class="pain-grid">
      <div class="pain-item reveal">
        <span class="pain-number">01</span>
        <span class="pain-icon">💸</span>
        <div class="pain-title">Promises Without Proof</div>
        <p class="pain-desc">Most serums use ingredients at <strong>5–10× below</strong> the concentration required to show clinical results. The label says niacinamide. The formula has barely any.</p>
      </div>
      <div class="pain-item reveal stagger-1">
        <span class="pain-number">02</span>
        <span class="pain-icon">⏳</span>
        <div class="pain-title">Too Little Too Late</div>
        <p class="pain-desc">Your skin loses <strong>1% of its collagen every year</strong> after 25. Most "anti-aging" products contain actives that can't penetrate deep enough to do anything about it.</p>
      </div>
      <div class="pain-item reveal stagger-2">
        <span class="pain-number">03</span>
        <span class="pain-icon">🏷️</span>
        <div class="pain-title">Luxury Tax on Hope</div>
        <p class="pain-desc">Department store markup adds <strong>400–800%</strong> to the cost of the actual formula. You're paying for the bottle, the shelf, and the influencer, not the ingredients.</p>
      </div>
    </div>
  </div>
</section>

<!-- ── PRODUCTS ───────────────────────────────────────────── -->
<section style="background:var(--bg);padding:clamp(80px,11vw,130px) 0;">
  <div class="container">
    <div class="products-header">
      <div>
        <div class="section-label reveal">The Collection</div>
        <h2 class="section-heading reveal">Every product earns<br>its place.</h2>
      </div>
      <a href="{{ routes.all_products_collection_url }}" class="btn-outline reveal">View All</a>
    </div>
    <div class="products-grid">
      {%- for product in collections.all.products limit: 3 -%}
      <div class="product-card reveal stagger-{{ forloop.index }}" data-category="{{ product.type | downcase | replace: ' ', '-' }}">
        <a href="{{ product.url }}">
          <div class="product-card-visual">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 480 }}" alt="{{ product.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;">
            {%- else -%}
              {%- case product.handle -%}
              {%- when 'niacinamide-10-zinc-serum' -%}
                <div style="width:72px;height:140px;background:linear-gradient(160deg,#4E7A69,#2D4A40,#1a2e27);border-radius:10px 10px 18px 18px;box-shadow:0 16px 48px rgba(45,74,64,0.35);"></div>
              {%- when 'copper-peptide-renewal-serum' -%}
                <div style="width:72px;height:140px;background:linear-gradient(160deg,#c4924a,#8b5e2a,#4a2e14);border-radius:10px 10px 18px 18px;box-shadow:0 16px 48px rgba(139,94,42,0.35);"></div>
              {%- when '24k-gold-under-eye-patches' -%}
                <div style="display:flex;gap:10px;align-items:center;">
                  <div style="width:50px;height:28px;background:linear-gradient(135deg,#d4a255,#b8924a);border-radius:50% 50% 50% 50% / 60% 60% 40% 40%;box-shadow:0 8px 24px rgba(184,146,74,0.4);"></div>
                  <div style="width:50px;height:28px;background:linear-gradient(135deg,#d4a255,#b8924a);border-radius:50% 50% 50% 50% / 60% 60% 40% 40%;box-shadow:0 8px 24px rgba(184,146,74,0.4);"></div>
                </div>
              {%- when 'led-photon-therapy-mask' -%}
                <div style="width:120px;height:80px;background:linear-gradient(135deg,#1a1a2e,#2d1b69);border-radius:50%;border:4px solid rgba(255,50,50,0.4);box-shadow:0 0 30px rgba(255,50,50,0.3);"></div>
              {%- when 'jade-facial-roller-gua-sha-set' -%}
                <div style="width:28px;height:110px;background:linear-gradient(180deg,#5a9e7a,#3d7a58);border-radius:14px;box-shadow:0 8px 24px rgba(61,122,88,0.4);"></div>
              {%- else -%}
                <div style="width:72px;height:140px;background:linear-gradient(160deg,var(--forest-3),var(--forest));border-radius:10px 10px 18px 18px;"></div>
              {%- endcase -%}
            {%- endif -%}
            <span class="card-badge">{% if product.tags contains 'bestseller' %}Best Seller{% elsif product.tags contains 'new' %}New{% else %}{{ product.type }}{% endif %}</span>
          </div>
        </a>
        <div class="product-card-body">
          <div class="card-category">{{ product.type }}</div>
          <a href="{{ product.url }}"><div class="card-name">{{ product.title }}</div></a>
          <p class="card-desc">{%- assign ph = product.handle -%}{%- if ph contains 'niacinamide' -%}20% niacinamide, twice the clinical benchmark. Zinc PCA controls oil. Visible pore reduction in 4 weeks.{%- elsif ph contains 'copper' or ph contains 'peptide' -%}GHK-Cu at clinical dose. Signals collagen production your skin lost after 25. Results in 4 weeks.{%- elsif ph contains 'gold' or ph contains 'eye' -%}24K gold, HA, retinol, caffeine. 20 minutes per session. Visible reduction in puffiness and dark circles.{%- elsif ph contains 'led' or ph contains 'mask' or ph contains 'therapy' -%}630nm + 415nm LEDs. Collagen and acne, clinically. 3 minutes a session instead of $150 at a clinic.{%- elsif ph contains 'jade' or ph contains 'roller' or ph contains 'gua' -%}Real jade roller and gua sha. De-puffs in 5 minutes, drives your serums deeper into skin.{%- else -%}{{ product.description | strip_html | truncate: 90 }}{%- endif -%}</p>
          <div class="card-footer">
            <div class="card-price">{{ product.price | money }}<span>CAD</span></div>
            <a href="{{ product.url }}" class="btn-card">
              Shop Now
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>
      </div>
      {%- endfor -%}
    </div>
  </div>
</section>

